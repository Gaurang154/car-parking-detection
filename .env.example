# Video source — file path or camera index (0 for webcam)
VIDEO_SOURCE=carPark.mp4

# Detection tuning
SPACE_WIDTH=107
SPACE_HEIGHT=48
PIXEL_THRESHOLD=900
SMOOTHING_FRAMES=3

# Engine: "classical" or "yolo"
DEFAULT_ENGINE=classical

# YOLOv8 (OpenCV DNN, CPU ONNX)
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_OCCUPANCY_OVERLAP=0.30
# YOLO_MODEL_PATH=models/yolov8n.onnx

# Snapshot interval for occupancy history (seconds)
HISTORY_INTERVAL_SEC=5

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Paths
IMG_PATH=carParkImg.png
POSITIONS_PATH=data/positions.json
HISTORY_DB_PATH=data/history.db
